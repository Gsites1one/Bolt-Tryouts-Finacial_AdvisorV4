# ─────────────────────────────────────────────────────────────────────
# Aura Capital — environment variables template
#
# Copy this file to `.env` (which is gitignored) and fill in the values.
# In production (Vercel), set these in Project Settings → Environment Variables.
#
# Vite only exposes variables prefixed with `VITE_` to the browser bundle.
# ─────────────────────────────────────────────────────────────────────

# Web3Forms access key — powers the contact form submission.
# Sign up at https://web3forms.com and paste the access key here.
# When this key is missing, ContactForm runs in demo mode (simulated success).
VITE_WEB3FORMS_KEY=
